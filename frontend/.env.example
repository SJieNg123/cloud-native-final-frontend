# API 基底（開發時建議走 Vite proxy，避免 CORS）
VITE_API_BASE_URL=/api/v1

# WebSocket 可先留空，讓前端依 API base 自動推導
# VITE_WS_BASE_URL=

# Vite dev proxy target（當 VITE_API_BASE_URL=/api/v1 時使用）
VITE_DEV_PROXY_API_TARGET=https://cets.alanh.uk
VITE_DEV_PROXY_WS_TARGET=wss://cets.alanh.uk

# Playwright E2E 後端目標
E2E_API_BASE_URL=https://cets.alanh.uk/api/v1
E2E_WS_BASE_URL=wss://cets.alanh.uk/ws
